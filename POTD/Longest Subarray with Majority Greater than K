// Brute Force
// Time: O(n²)
// Space: O(1)
-----------------------------------------------------------------------------------------------
-----------------------------------------------------------------------------------------------
class Solution {
    public int longestSubarray(int[] arr, int k) {
        // Code Here
        int n = arr.length;
        
        int maxLen = 0;
        
        for(int i = 0; i < n; i++)
        {
            int cLE = 0;
            int cM = 0;
            
            for(int j = i; j < n; j++)
            {
                if(arr[j] <= k)
                    cLE++;
                else
                    cM++;
                    
                if(cM > cLE)
                    maxLen = Math.max(maxLen, j - i + 1);
            }
        }
        
        return maxLen;
        
    }
}
