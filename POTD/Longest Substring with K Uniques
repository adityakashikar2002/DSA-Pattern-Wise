// Brute Force
// Time: O(n²)
// Space: O(k) or O(1)
----------------------------------------------------------------------------------
----------------------------------------------------------------------------------
class Solution {
    public int longestKSubstr(String s, int k) {
        // code here
        int n = s.length();
        
        int maxLen = -1;
        
        for(int i = 0; i < n; i++)
        {
            int count = 0;
            
            Set<Character> seen = new HashSet<>();
            
            for(int j = i; j < n; j++)
            {
                seen.add(s.charAt(j));
                
                if(seen.size() > k)
                    break;
                    
                if(seen.size() == k)
                    maxLen = Math.max(maxLen, j - i + 1);
            }
        }
        
        return maxLen;
    }
}
