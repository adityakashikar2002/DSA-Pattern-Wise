// Brute Force
// Time: O(n²)
// Space: O(1)
-------------------------------------------------------------------------------------------
-------------------------------------------------------------------------------------------
class Solution {
    public int totalElements(int[] arr) {
        // code here
        int n = arr.length;
        
        int maxLen = 0;
        
        for(int i = 0; i < n; i++)
        {
            int count = 0;
            Set<Integer> seen = new HashSet<>();
            for(int j = i; j < n; j++)
            {
                seen.add(arr[j]);
                
                if(seen.size() > 2)
                    break;
                    
                maxLen = Math.max(maxLen, j - i + 1);
            }
        }
        
        return maxLen;
    }
}
