// Brute Approach
// Time: O(n²)
// Space: O(1)
------------------------------------------------------------------------------------------------
------------------------------------------------------------------------------------------------
class Solution {
    public int equalSumSpan(int[] a1, int[] a2) {
        // code here
        int n = a1.length;
        
        int maxLen = 0;
        
        for(int i = 0; i < n; i++)
        {
            int sum1 = 0;
            int sum2 = 0;
            
            for(int j = i; j < n; j++)
            {
                sum1 += a1[j];
                sum2 += a2[j];
                
                if(sum1 == sum2)
                {
                    maxLen = Math.max(maxLen, j - i + 1);
                }
                    
            }
        }
        
        return maxLen;
    }
}
