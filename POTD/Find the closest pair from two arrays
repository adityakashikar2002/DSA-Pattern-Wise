// Brute Force
// Time: O(n x m)
// Space: O(n x m)
------------------------------------------------------------------------------------------------
------------------------------------------------------------------------------------------------
class Solution {
    public static ArrayList<Integer> findClosestPair(int arr1[], int arr2[], int x) {
        // code here
        int n = arr1.length;
        int m = arr2.length;
        
        HashMap<Integer, ArrayList<Integer>> map = new HashMap<>();
        int minDiff = Integer.MAX_VALUE;
        
        for(int i = 0; i < n; i++)
        {
            int sum = 0;
            
            for(int j = 0; j < m; j++)
            {
                sum = arr1[i] + arr2[j];
                
                int diff = Math.abs(x - sum);
                
                minDiff = Math.min(minDiff, diff);
                
                map.put(diff, new ArrayList<>(Arrays.asList(arr1[i], arr2[j])));
            }
        }
        
        return map.get(minDiff);
    }
}
