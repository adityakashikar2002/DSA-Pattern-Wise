// Approach 2 : Without Using XOR Prefix Array
// Time: O(n)
// Space: O(n)
----------------------------------------------------------------------------------------------------
----------------------------------------------------------------------------------------------------
class Solution {
    public long subarrayXor(int arr[], int k) {
        // code here
        int n = arr.length;
        int count = 0;
        
        int prefixXOR = 0;
        
        HashMap<Integer, Integer> map = new HashMap<>();
        
        for(int i = 0; i < n; i++)
        {
            prefixXOR ^= arr[i];
            
            if(prefixXOR == k)
                count++;
            
            if(map.containsKey(prefixXOR ^ k))
                count += map.get(prefixXOR ^ k);
            
            map.put(prefixXOR, map.getOrDefault(prefixXOR, 0) + 1);
        }
        
        return count;
    }
}
